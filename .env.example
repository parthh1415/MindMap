# Copy to .env and fill in values. .env is gitignored.

# --- Backend ---
MONGO_URI=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
# Artifact generation needs longer/more reliable structured output —
# nano was emitting malformed 110KB blobs. Mini is still cheap.
OPENAI_ARTIFACT_MODEL=gpt-4.1-mini
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Agents ---
AGENTVERSE_API_KEY=
TOPOLOGY_AGENT_SEED=
ENRICHMENT_AGENT_SEED=
TOPOLOGY_AGENT_PORT=8001
ENRICHMENT_AGENT_PORT=8002

# --- Frontend ---
VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_WS_URL=ws://localhost:8000
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Transcript provider chain (AssemblyAI → ElevenLabs → Web Speech) ---
# AssemblyAI: server-side key only — NEVER prefix with VITE_. Backend mints
# short-lived temp tokens at /internal/assembly-token; the browser only
# ever sees the temp token.
ASSEMBLYAI_API_KEY=
# ElevenLabs Scribe v2: browser-direct, key must be a scoped STT-only key.
VITE_ELEVENLABS_API_KEY=
